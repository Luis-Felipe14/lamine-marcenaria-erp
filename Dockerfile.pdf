# Servidor PDF (Puppeteer) - deploy separado do frontend Cloudflare
FROM node:20-bookworm-slim

RUN apt-get update && apt-get install -y \
    chromium \
    fonts-liberation \
    ca-certificates \
    --no-install-recommends \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV NODE_ENV=production
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV SKIP_PUPPETEER_INSTALL=true
ENV NODE_OPTIONS=--max-old-space-size=192

COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts

COPY server ./server
COPY src/pdf ./src/pdf
COPY src/lib ./src/lib
COPY tsconfig.pdf-server.json ./

# Só assets leves para o PDF (evita lamine-logo.png ~1.7MB no container)
COPY public/lamine-logo.svg public/lamine-monogram.svg public/lamine-background.png ./public/
COPY public/login/slide-1.svg ./public/login/

EXPOSE 10000

CMD ["npm", "run", "pdf:server:prod"]
