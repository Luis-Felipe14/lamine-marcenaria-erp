{
  "name": "lamine-erp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -k -n app,pdf -c cyan,magenta \"vite\" \"npm run pdf:server\"",
    "pdf:server": "tsx --tsconfig tsconfig.pdf-server.json --env-file=.env server/pdf-server.ts",
    "pdf:install-browser": "puppeteer browsers install chrome",
    "postinstall": "node scripts/ensure-puppeteer-chrome.mjs",
    "build": "tsc -b && vite build",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:cloudflare": "npx wrangler deploy --assets=./dist",
    "deploy:cloudflare:preview": "npx wrangler versions upload --assets=./dist"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-virtual": "^3.14.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.513.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "react-router-dom": "^7.16.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.14",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "puppeteer": "^24.36.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "concurrently": "^9.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "tsx": "^4.20.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.8",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
